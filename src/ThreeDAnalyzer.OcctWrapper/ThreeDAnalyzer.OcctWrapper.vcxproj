<?xml version="1.0" encoding="utf-8"?>
<!--
  ThreeDAnalyzer.OcctWrapper — C++/CLI Managed Wrapper for OCCT 7.8
  Requirements:
    • Visual Studio 2022 (v143 toolset)
    • OCCT 7.8 for Windows x64 — https://dev.opencascade.org/release
    • Set OCCT_ROOT environment variable (or edit IncludePath/LibraryPath below)
      e.g. OCCT_ROOT=C:\OpenCASCADE-7.8.0-vc14-64
  Build: x64 | Release  (then rebuild ThreeDAnalyzer.Web with -p:UseOcct=true)
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{B2A3C4D5-E6F7-4A8B-9C0D-1E2F3A4B5C6D}</ProjectGuid>
    <Keyword>ManagedCProj</Keyword>
    <RootNamespace>ThreeDAnalyzer.OcctWrapper</RootNamespace>
    <ProjectName>ThreeDAnalyzer.OcctWrapper</ProjectName>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <!-- ── Debug x64 ───────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v145</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <CLRSupport>NetCore</CLRSupport>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>
  <!-- ── Release x64 ─────────────────────────────────────────────── -->
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v145</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
    <CLRSupport>NetCore</CLRSupport>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings" />
  <ImportGroup Label="Shared" />
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <!-- ── Compiler / Linker (shared) ──────────────────────────────── -->
  <ItemDefinitionGroup>
    <ClCompile>
      <!--
        $(OCCT_ROOT)\inc  — OCCT public headers
        Add more paths here if OCCT splits headers into sub-packages
      -->
      <AdditionalIncludeDirectories>$(OCCT_ROOT)\inc;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>WIN32;_WINDOWS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <ExceptionHandling>Async</ExceptionHandling>
      <RuntimeLibrary Condition="'$(Configuration)'=='Debug'">MultiThreadedDebugDLL</RuntimeLibrary>
      <RuntimeLibrary Condition="'$(Configuration)'=='Release'">MultiThreadedDLL</RuntimeLibrary>
    </ClCompile>
    <Link>
      <!--
        $(OCCT_ROOT)\win64\vc14\lib  — OCCT import libraries
        Adjust the path suffix if your OCCT layout differs.
      -->
      <AdditionalLibraryDirectories>$(OCCT_ROOT)\win64\vc14\lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>
        TKernel.lib;
        TKMath.lib;
        TKBRep.lib;
        TKTopAlgo.lib;
        TKGeomAlgo.lib;
        TKGeomBase.lib;
        TKBool.lib;
        TKPrim.lib;
        TKMesh.lib;
        TKDESTEP.lib;
        TKXSBase.lib;
        TKG3d.lib;
        TKG2d.lib;
        TKShHealing.lib;
        %(AdditionalDependencies)
      </AdditionalDependencies>
      <SubSystem>Windows</SubSystem>
    </Link>
  </ItemDefinitionGroup>
  <!-- ── Source files ─────────────────────────────────────────────── -->
  <ItemGroup>
    <ClCompile Include="OcctWrapper.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="OcctWrapper.h" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets" />
</Project>